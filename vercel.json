{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/begin", "dest": "/begin.html" },
    { "src": "/earth", "dest": "/earth.html" },
    { "src": "/sky", "dest": "/sky.html" },
    { "src": "/life", "dest": "/life.html" },
    { "src": "/mirror", "dest": "/mirror.html" },
    { "src": "/map", "dest": "/map.html" },
    { "src": "/signals", "dest": "/signals.html" },
    { "src": "/intake", "dest": "/intake.html" },
    { "src": "/offerings", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
